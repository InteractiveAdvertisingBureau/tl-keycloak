# Copy to `.env` in this directory. Docker Compose reads only this file at the repo root.
# Local: use with `docker-compose.local-db.yml` for bundled MySQL/Postgres, or set Cloud SQL
# variables below for a VM / GCP deployment (no second env file).

# --- Auth0 (keycloak-api, api-gateway, frontend build args)
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
AUTH0_AUDIENCE=https://your-api-identifier.example.com
AUTH0_REDIRECT_URI=http://localhost:4010/callback
AUTH0_ACTIONS_SECRET=changeme-actions
AUTH0_ISSUER=

FRONTEND_URL=http://localhost:4003
# Public URL for keycloak-api (Compose default). Auth0 Action secret BACKEND_URL should point at the **gateway** (e.g. same host as VITE_GATEWAY_BASE_URL over HTTPS / tunnel), not this value, unless you proxy webhooks yourself.
BACKEND_PUBLIC_URL=http://localhost:4004
VITE_GATEWAY_BASE_URL=http://localhost:4010
VITE_AUTH0_REDIRECT_URI=http://localhost:4010/callback

# Optional VITE overrides (else AUTH0_* are used)
# VITE_AUTH0_DOMAIN=
# VITE_AUTH0_CLIENT_ID=
# VITE_AUTH0_AUDIENCE=

# api-gateway / Keycloak JWT (optional)
# KEYCLOAK_INTERNAL_BASE_URL=http://keycloak:8080
# KEYCLOAK_JWKS_URI=
# KEYCLOAK_AUDIENCE=

# --- Keycloak (Quarkus): database is Postgres (Cloud SQL or local `postgres` service)
# Default DB name in compose is tl_keycloak_qa (must match Postgres). KC_DB is always "postgres" (vendor), not the DB name.
# If you previously used DB name `keycloak` with docker-compose.local-db.yml, recreate the postgres volume or migrate data.
# Local with docker-compose.local-db.yml: omit KC_DB_* to use defaults (docker host `postgres`).
# Cloud SQL example (use your instance IP/connection and sslmode if required):
# KC_DB_URL=jdbc:postgresql://10.0.0.3:5432/tl_keycloak_qa?sslmode=require
# KC_DB_USERNAME=keycloak
# KC_DB_PASSWORD=
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
# Keycloak behind HTTPS reverse proxy (fixes browser “mixed content” if admin loads http://…/resources/…):
# KC_PROXY_HEADERS=xforwarded
# KC_HOSTNAME=https://keycloak.devjs.in

# --- authz-service: MySQL (Cloud SQL or local `mysql` service)
# Local with docker-compose.local-db.yml: omit MYSQL_* to use defaults (docker host `mysql`).
# Cloud SQL example:
# MYSQL_HOST=10.0.0.4
MYSQL_PORT=3306
MYSQL_USER=authz
MYSQL_PASSWORD=authz
MYSQL_DATABASE=authz

# --- AuthZ seed / admin mapping
AUTHZ_ADMIN_SUB=auth0|demo-admin-sub
AUTHZ_ADMIN_EMAIL=admin@example.com

# --- Optional host port overrides
# POSTGRES_HOST_PORT=5432
# KEYCLOAK_API_HOST_PORT=4004
# GATEWAY_HOST_PORT=4010
# FRONTEND_HOST_PORT=4003

# --- api-gateway production edge (see docs/architecture.md)
# Comma-separated public Host values. When set, non-matching Host returns 403 (GET /health is exempt).
# GATEWAY_ALLOWED_HOSTS=auth.iabtechlab.ai,api.iabtechlab.ai,tools.iabtechlab.ai,keycloak.iabtechlab.ai
# When behind nginx/Cloudflare, set so req.hostname reflects the browser host (Express trust proxy).
# GATEWAY_TRUST_PROXY=1
