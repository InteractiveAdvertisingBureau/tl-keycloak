# Copy to `.env` in this directory for `docker compose` variable substitution.
# Auth0 (required for keycloak-api + api-gateway + frontend build args)
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
# Required for Auth0 password + /callback: Auth0 API "Identifier" (Dashboard → Applications → APIs → your API).
# Without it, Auth0 returns opaque access tokens and the api-gateway cannot verify /me.
AUTH0_AUDIENCE=https://your-api-identifier.example.com
AUTH0_REDIRECT_URI=http://localhost:4010/callback

# api-gateway — Keycloak JWTs: leave KEYCLOAK_JWKS_URI unset so realm is taken from the token iss,
# or set KEYCLOAK_JWKS_URI to override. Use KEYCLOAK_INTERNAL_BASE_URL if Keycloak isn’t at http://keycloak:8080 from the gateway container.
# KEYCLOAK_INTERNAL_BASE_URL=http://keycloak:8080
# KEYCLOAK_JWKS_URI=
# KEYCLOAK_AUDIENCE=

FRONTEND_URL=http://localhost:4003
VITE_GATEWAY_BASE_URL=http://localhost:4010
# Optional overrides; docker-compose defaults these from AUTH0_* above when unset.
# VITE_AUTH0_DOMAIN=
# VITE_AUTH0_CLIENT_ID=
# VITE_AUTH0_AUDIENCE=
VITE_AUTH0_REDIRECT_URI=http://localhost:4010/callback

AUTH0_ACTIONS_SECRET=changeme-actions
BACKEND_PUBLIC_URL=http://localhost:4004

# Optional: map AuthZ admin seed to your real Auth0 `sub`
AUTHZ_ADMIN_SUB=auth0|demo-admin-sub
