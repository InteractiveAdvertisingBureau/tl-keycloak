PORT=3000
NODE_ENV=development

# Auth0 (required if validating Auth0 JWTs and /callback)
AUTH0_DOMAIN=your-tenant.auth0.com
# Optional; must match the JWT `iss` claim (required for some custom-domain setups).
AUTH0_ISSUER=
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
# Same Auth0 API identifier as keycloak-api (JWT access_token aud / resource).
AUTH0_AUDIENCE=https://your-api-identifier.example.com
AUTH0_REDIRECT_URI=http://localhost:4010/callback

# Keycloak JWT validation (required when tokens can be issued by Keycloak, e.g. after KC ROPG login)
KEYCLOAK_JWKS_URI=http://localhost:8080/realms/master/protocol/openid-connect/certs
# Optional audience check — set to your Keycloak client id if you enforce aud
KEYCLOAK_AUDIENCE=

FRONTEND_URL=http://localhost:4003
APP_BASE_PATH=

KEYCLOAK_API_URL=http://localhost:4004
AUTHZ_BASE_URL=http://localhost:4001
MOCK_SERVICE_URL=http://localhost:4002

CORS_ORIGIN=*
