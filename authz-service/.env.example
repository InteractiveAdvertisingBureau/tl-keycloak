PORT=4001
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_USER=authz
MYSQL_PASSWORD=authz
MYSQL_DATABASE=authz
AUTHZ_CACHE_TTL_MS=60000
# JWT sub for admin user (must match Auth0 user sub in tokens)
AUTHZ_ADMIN_SUB=auth0|demo-admin-sub
AUTHZ_ADMIN_EMAIL=admin@example.com
AUTHZ_DEMO_USER_SUB=auth0|demo-user-sub
AUTHZ_DEMO_USER_EMAIL=user@example.com
