# Gateway origin (API + SDK script URL). Auth0 Actions should use this same public origin as BACKEND_URL (HTTPS in production).
VITE_GATEWAY_BASE_URL=http://localhost:4010

# Optional: Auth0 Universal Login (SDK loginWithAuth0). With docker compose, these default from AUTH0_* in root .env.
VITE_AUTH0_DOMAIN=your-tenant.auth0.com
VITE_AUTH0_CLIENT_ID=
# Must match Auth0 API identifier (same as AUTH0_AUDIENCE on the gateway).
VITE_AUTH0_AUDIENCE=https://your-api-identifier.example.com
# Must match api-gateway /callback (gateway exchanges code, then redirects to FRONTEND_URL#tokens)
VITE_AUTH0_REDIRECT_URI=http://localhost:4010/callback
