PORT=4000
NODE_ENV=development

# Auth0 (optional: Resource Owner Password / OAuth for users who exist in Auth0 — POST /signup does NOT register in Auth0)
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
# Auth0 API identifier — required so password grant returns a JWT access_token the gateway can verify.
AUTH0_AUDIENCE=https://your-api-identifier.example.com
AUTH0_CONNECTION=Username-Password-Authentication
AUTH0_SCOPE=openid profile email
# Must match JWT iss (optional; default https://<AUTH0_DOMAIN>/)
AUTH0_ISSUER=

# Internal authz service (canonical user id + identity mapping)
AUTHZ_BASE_URL=http://localhost:4001

# Keycloak Admin API
KEYCLOAK_BASE_URL=http://localhost:8080
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=master
KC_ADMIN_USERNAME=admin
KC_ADMIN_PASSWORD=admin
KC_ADMIN_CLIENT_ID=admin-cli
# Optional: KEYCLOAK_USE_CLIENT_CREDENTIALS=true
# KEYCLOAK_CLIENT_ID=
# KEYCLOAK_CLIENT_SECRET=

# Resource Owner Password grant client (realm user) — required for KC-only login via POST /login
KEYCLOAK_ROPG_CLIENT_ID=
# KEYCLOAK_ROPG_CLIENT_SECRET=
# KEYCLOAK_ROPG_SCOPE=openid profile email

# Optional: page size when scanning Keycloak users by auth0_id (default 100, max 200)
# KEYCLOAK_USER_LIST_PAGE_SIZE=100

# Auth0 Actions webhooks (Bearer must match Action secret ACTIONS_SECRET in Auth0)
AUTH0_ACTIONS_SECRET=your-actions-secret
# Optional: documented public URL for operators. Auth0 Action BACKEND_URL = api-gateway origin (see README / docs/auth-flow.md).
BACKEND_PUBLIC_URL=http://localhost:4004
