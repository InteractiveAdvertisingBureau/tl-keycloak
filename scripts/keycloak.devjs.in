# /etc/nginx/sites-available/keycloak.devjs.in
#
# Three public hostnames under devjs.in (hyphenated labels — no auth.x.y “sub-subdomain”):
#   https://auth-keycloak.devjs.in/   → 127.0.0.1:4010  (api-gateway: /sdk/v1, /callback, …)
#   https://api-keycloak.devjs.in/    → 127.0.0.1:4010  (api-gateway: /login, /webhooks, /me, …)
#   https://tools-keycloak.devjs.in/  → 127.0.0.1:4003 (frontend SPA; use VITE_BASE_PATH=/ or match your build)
#
# Ports match docker-compose.yml defaults: GATEWAY_HOST_PORT=4010, FRONTEND_HOST_PORT=4003 (override in .env if needed).
#
# Gateway: use APP_BASE_PATH="" (no /api prefix). Point Auth0 callback to auth host; Actions BACKEND_URL to api host.
# Optional Host allowlist: GATEWAY_ALLOWED_HOSTS=auth-keycloak.devjs.in,api-keycloak.devjs.in,tools-keycloak.devjs.in
#   and GATEWAY_TRUST_PROXY=1 so the gateway sees the browser hostname.
#
# Keycloak (8080) is not on these three names. Options: (1) SSH / internal only, (2) add a fourth server_name
#   e.g. keycloak.devjs.in → 127.0.0.1:8080, (3) Cloudflare Tunnel to :8080. Do not mount SPA at KC /admin.
#
# TLS: issue one certificate covering all three names (SAN), or separate certs per host; adjust ssl_certificate
#   paths below to match certbot’s live directory (often the first -d name).

# --- ACME / HTTP → HTTPS (all three hosts) ---
server {
    listen 80;
    listen [::]:80;
    server_name auth-keycloak.devjs.in api-keycloak.devjs.in tools-keycloak.devjs.in;

    location /.well-known/acme-challenge/ {
        root /var/www/html;
    }

    location / {
        return 301 https://$host$request_uri;
    }
}

# --- HTTPS: auth → api-gateway (SDK, OAuth callback, redirects) ---
server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name auth-keycloak.devjs.in;

    ssl_certificate     /etc/letsencrypt/live/auth-keycloak.devjs.in/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/auth-keycloak.devjs.in/privkey.pem;
    ssl_trusted_certificate /etc/letsencrypt/live/auth-keycloak.devjs.in/chain.pem;

    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers off;
    ssl_session_cache shared:SSL:10m;
    ssl_session_timeout 10m;

    client_max_body_size 10M;

    location / {
        proxy_pass http://127.0.0.1:4010;
        proxy_http_version 1.1;

        proxy_set_header Authorization $http_authorization;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header X-Forwarded-Port $server_port;

        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';

        proxy_buffer_size 128k;
        proxy_buffers 4 256k;
        proxy_busy_buffers_size 256k;

        proxy_read_timeout 300;
    }
}

# --- HTTPS: api → api-gateway (JSON APIs, webhooks, JWT routes, keycloak-api proxy) ---
server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name api-keycloak.devjs.in;

    ssl_certificate     /etc/letsencrypt/live/api-keycloak.devjs.in/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/api-keycloak.devjs.in/privkey.pem;
    ssl_trusted_certificate /etc/letsencrypt/live/api-keycloak.devjs.in/chain.pem;

    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers off;
    ssl_session_cache shared:SSL:10m;
    ssl_session_timeout 10m;

    client_max_body_size 10M;

    location / {
        proxy_pass http://127.0.0.1:4010;
        proxy_http_version 1.1;

        proxy_set_header Authorization $http_authorization;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header X-Forwarded-Port $server_port;

        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';

        proxy_buffer_size 128k;
        proxy_buffers 4 256k;
        proxy_busy_buffers_size 256k;

        proxy_read_timeout 300;
    }
}

# --- HTTPS: tools → portal SPA ---
server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name tools-keycloak.devjs.in;

    ssl_certificate     /etc/letsencrypt/live/tools-keycloak.devjs.in/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/tools-keycloak.devjs.in/privkey.pem;
    ssl_trusted_certificate /etc/letsencrypt/live/tools-keycloak.devjs.in/chain.pem;

    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers off;
    ssl_session_cache shared:SSL:10m;
    ssl_session_timeout 10m;

    client_max_body_size 10M;

    location / {
        proxy_pass http://127.0.0.1:4003;
        proxy_http_version 1.1;

        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header X-Forwarded-Port $server_port;

        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';

        proxy_read_timeout 300;
    }
}
