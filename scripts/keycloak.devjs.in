# /etc/nginx/sites-available/keycloak.devjs.in
#
# Hostnames use a single label under devjs.in (not auth.keycloak… — that would be a nested subdomain):
#   auth-keycloak.devjs.in   → gateway :4010  (SDK, /callback)
#   api-keycloak.devjs.in    → gateway :4010  (/login, webhooks, /me, …)
#   tools-keycloak.devjs.in  → frontend :4003 (portal SPA)
#   keycloak.devjs.in        → Keycloak :8080 (Admin Console https://keycloak.devjs.in/admin/ — uses existing cert)
#
# --- VM checklist (after editing this file for your real domain if not devjs.in) ---
# 1. DNS: A/AAAA for auth-keycloak, api-keycloak, tools-keycloak, keycloak.devjs.in → this server’s public IP.
# 2. TLS: certbot (SAN) e.g. certbot certonly --webroot -w /var/www/html \
#      -d auth-keycloak.devjs.in -d api-keycloak.devjs.in -d tools-keycloak.devjs.in
#    Point all three ssl_certificate* blocks at the same live/… dir if one cert was issued.
#    Or use DNS challenge for *.devjs.in wildcard (then set identical ssl paths in each server block).
# 3. Copy this file to /etc/nginx/sites-available/, symlink sites-enabled, nginx -t, systemctl reload nginx.
# 4. .env on VM: APP_BASE_PATH=""; FRONTEND_URL=https://tools-keycloak.devjs.in;
#    AUTH0_REDIRECT_URI=https://auth-keycloak.devjs.in/callback; VITE_* URLs consistent;
#    Auth0 Actions BACKEND_URL=https://api-keycloak.devjs.in (no trailing slash);
#    GATEWAY_ALLOWED_HOSTS=auth-keycloak.devjs.in,api-keycloak.devjs.in,tools-keycloak.devjs.in; GATEWAY_TRUST_PROXY=1.
# 5. docker compose up -d (Keycloak publishes host :8080 per docker-compose.yml).
#
# Ports match docker-compose.yml: GATEWAY_HOST_PORT=4010, FRONTEND_HOST_PORT=4003, Keycloak 8080:8080.

# --- ACME / HTTP → HTTPS (all public hostnames) ---
server {
    listen 80;
    listen [::]:80;
    server_name auth-keycloak.devjs.in api-keycloak.devjs.in tools-keycloak.devjs.in keycloak.devjs.in;

    location /.well-known/acme-challenge/ {
        root /var/www/html;
    }

    location / {
        return 301 https://$host$request_uri;
    }
}

# --- HTTPS: auth → api-gateway (SDK, OAuth callback, redirects) ---
server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name auth-keycloak.devjs.in;

    ssl_certificate     /etc/letsencrypt/live/auth-keycloak.devjs.in/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/auth-keycloak.devjs.in/privkey.pem;
    ssl_trusted_certificate /etc/letsencrypt/live/auth-keycloak.devjs.in/chain.pem;

    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers off;
    ssl_session_cache shared:SSL:10m;
    ssl_session_timeout 10m;

    client_max_body_size 10M;

    location / {
        proxy_pass http://127.0.0.1:4010;
        proxy_http_version 1.1;

        proxy_set_header Authorization $http_authorization;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header X-Forwarded-Port $server_port;

        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';

        proxy_buffer_size 128k;
        proxy_buffers 4 256k;
        proxy_busy_buffers_size 256k;

        proxy_read_timeout 300;
    }
}

# --- HTTPS: api → api-gateway (JSON APIs, webhooks, JWT routes, keycloak-api proxy) ---
server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name api-keycloak.devjs.in;

    ssl_certificate     /etc/letsencrypt/live/api-keycloak.devjs.in/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/api-keycloak.devjs.in/privkey.pem;
    ssl_trusted_certificate /etc/letsencrypt/live/api-keycloak.devjs.in/chain.pem;

    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers off;
    ssl_session_cache shared:SSL:10m;
    ssl_session_timeout 10m;

    client_max_body_size 10M;

    location / {
        proxy_pass http://127.0.0.1:4010;
        proxy_http_version 1.1;

        proxy_set_header Authorization $http_authorization;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header X-Forwarded-Port $server_port;

        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';

        proxy_buffer_size 128k;
        proxy_buffers 4 256k;
        proxy_busy_buffers_size 256k;

        proxy_read_timeout 300;
    }
}

# --- HTTPS: tools → portal SPA ---
server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name tools-keycloak.devjs.in;

    ssl_certificate     /etc/letsencrypt/live/tools-keycloak.devjs.in/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/tools-keycloak.devjs.in/privkey.pem;
    ssl_trusted_certificate /etc/letsencrypt/live/tools-keycloak.devjs.in/chain.pem;

    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers off;
    ssl_session_cache shared:SSL:10m;
    ssl_session_timeout 10m;

    client_max_body_size 10M;

    location / {
        proxy_pass http://127.0.0.1:4003;
        proxy_http_version 1.1;

        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header X-Forwarded-Port $server_port;

        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';

        proxy_read_timeout 300;
    }
}

# --- HTTPS: Keycloak (Admin + realm UIs) — existing Lets Encrypt cert ---
# If Keycloak redirects to the wrong host/port, set on the Keycloak container e.g. KC_HOSTNAME=keycloak.devjs.in
# and KC_HOSTNAME_ADMIN=keycloak.devjs.in (see Keycloak “hostname” docs for your image version).
server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name keycloak.devjs.in;

    ssl_certificate     /etc/letsencrypt/live/keycloak.devjs.in/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/keycloak.devjs.in/privkey.pem;
    ssl_trusted_certificate /etc/letsencrypt/live/keycloak.devjs.in/chain.pem;

    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers off;
    ssl_session_cache shared:SSL:10m;
    ssl_session_timeout 10m;

    client_max_body_size 10M;

    location / {
        proxy_pass http://127.0.0.1:8080;
        proxy_http_version 1.1;

        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header X-Forwarded-Port $server_port;

        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';

        proxy_buffer_size 128k;
        proxy_buffers 4 256k;
        proxy_busy_buffers_size 256k;

        proxy_read_timeout 300;
    }
}
